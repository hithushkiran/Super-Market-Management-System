    {
      "name": "06 – POST /api/products",
      "item": [
        {
          "name": "TC-P01 Create Product – Valid (All Fields)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Orange Juice\",\n  \"category\": \"Beverages\",\n  \"price\": 3.49,\n  \"quantity\": 100,\n  \"expiryDate\": \"2026-12-31T00:00:00Z\",\n  \"imageUrl\": \"https://example.com/orange-juice.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            },
            "description": "TC-P01 / TC-P03 / TC-P04 – Creates a product with all valid fields. Auto-saves new ID to {{new_product_id}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-P01 Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "pm.test('TC-P01 Response has a numeric id', function () {",
                  "    pm.expect(json.id).to.be.a('number').and.above(0);",
                  "});",
                  "",
                  "pm.test('TC-P01 Name matches submitted value', function () {",
                  "    pm.expect(json.name).to.eql('Orange Juice');",
                  "});",
                  "",
                  "pm.test('TC-P01 Price matches submitted value', function () {",
                  "    pm.expect(json.price).to.eql(3.49);",
                  "});",
                  "",
                  "pm.test('TC-P01 isLowStock false for qty=100', function () {",
                  "    pm.expect(json.isLowStock).to.be.false;",
                  "});",
                  "",
                  "pm.test('TC-P03 Location header present', function () {",
                  "    pm.expect(pm.response.headers.get('Location')).to.include('/api/products/');",
                  "});",
                  "",
                  "pm.test('TC-P04 createdAt is set', function () {",
                  "    pm.expect(json.createdAt).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('TC-GI03 updatedAt is null on new product', function () {",
                  "    pm.expect(json.updatedAt).to.be.null;",
                  "});",
                  "",
                  "// Auto-save the new product ID for PUT / DELETE tests",
                  "pm.environment.set('new_product_id', json.id);",
                  "console.log('Auto-set new_product_id =', json.id);"
                ]
              }
            }
          ]
        },
