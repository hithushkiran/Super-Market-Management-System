{
  "info": {
    "_postman_id": "a1b2c3d4-0002-0002-0002-supermarket02",
    "name": "Supermarket Management API – Sprint 1",
    "description": "Complete API test collection for the Supermarket Management System.\nBase URL: http://localhost:5224/api\n\nImport the companion environment file (SupermarketAPI.postman_environment.json) before running.\n\nFolder order follows the recommended test execution sequence:\n1. Seed / Health Check\n2. GET endpoints\n3. POST (creates a product; auto-saves ID to {{new_product_id}})\n4. PUT\n5. DELETE",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5224/api",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": ["// Collection-level pre-request: nothing required"]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level test: verify Content-Type on all non-204 responses",
          "if (pm.response.code !== 204 && pm.response.code !== 404) {",
          "    pm.test('Content-Type is JSON', function () {",
          "        pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "    });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 – Health Check",
      "item": [
        {
          "name": "API Reachable",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            },
            "description": "Smoke test – confirm the API is running and reachable before executing the rest of the collection."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API is reachable – status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time < 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('Response is a JSON array', function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 – GET /api/products",
      "item": [
        {
          "name": "TC-G01 Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            },
            "description": "TC-G01 – Returns all products. Expects 200 and a JSON array."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-G01 Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('TC-G01 Body is an array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('TC-G03 Each product has required fields', function () {",
                  "    var products = pm.response.json();",
                  "    if (products.length === 0) { return; }",
                  "    var required = ['id','name','category','price','quantity','expiryDate','createdAt','isLowStock','isExpired'];",
                  "    products.forEach(function(p) {",
                  "        required.forEach(function(f) {",
                  "            pm.expect(p, 'Product missing field: ' + f).to.have.property(f);",
                  "        });",
                  "    });",
                  "});",
                  "",
                  "pm.test('TC-G03 isLowStock is true when quantity < 10', function () {",
                  "    var products = pm.response.json();",
                  "    products.forEach(function(p) {",
                  "        var expected = p.quantity < 10;",
                  "        pm.expect(p.isLowStock, 'isLowStock mismatch for product id=' + p.id).to.eql(expected);",
                  "    });",
                  "});",
                  "",
                  "pm.test('TC-G03 price is a positive number', function () {",
                  "    var products = pm.response.json();",
                  "    products.forEach(function(p) {",
                  "        pm.expect(p.price, 'Price for id=' + p.id).to.be.above(0);",
                  "    });",
                  "});",
                  "",
                  "// Auto-save first product ID for use in later requests",
                  "var products = pm.response.json();",
                  "if (products.length > 0) {",
                  "    pm.environment.set('product_id', products[0].id);",
                  "    console.log('Auto-set product_id =', products[0].id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 – GET /api/products/{id}",
      "item": [
        {
          "name": "TC-GI01 Get Product by Valid ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            },
            "description": "TC-GI01 / TC-GI02 – Get a single product. Expects 200 and all response fields."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-GI01 Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "pm.test('TC-GI02 All fields present', function () {",
                  "    var fields = ['id','name','category','price','quantity','expiryDate','imageUrl','createdAt','updatedAt','isLowStock','isExpired'];",
                  "    fields.forEach(function(f) {",
                  "        pm.expect(json, 'Missing field: ' + f).to.have.property(f);",
                  "    });",
                  "});",
                  "",
                  "pm.test('TC-GI01 id matches request', function () {",
                  "    pm.expect(json.id).to.eql(parseInt(pm.environment.get('product_id')));",
                  "});",
                  "",
                  "pm.test('TC-GI10 isLowStock correct', function () {",
                  "    pm.expect(json.isLowStock).to.eql(json.quantity < 10);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-GI06 Get Product – Non-Existent ID (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/99999",
              "host": ["{{base_url}}"],
              "path": ["products", "99999"]
            },
            "description": "TC-GI06 – Expects 404 when product does not exist."
