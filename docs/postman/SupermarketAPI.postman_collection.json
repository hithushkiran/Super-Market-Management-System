              "raw": "{{base_url}}/products/-1",
              "host": ["{{base_url}}"],
              "path": ["products", "-1"]
            },
            "description": "TC-GI08 – Negative ID accepted by route but no product exists. Expects 404."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-GI08 Status 404 for negative ID', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
