                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05 – GET /api/products/lowstock",
      "item": [
        {
          "name": "TC-LS01 Get Low Stock – Default Threshold (10)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/lowstock",
              "host": ["{{base_url}}"],
              "path": ["products", "lowstock"]
            },
            "description": "TC-LS01 / TC-LS08 – Default threshold=10. All returned products should have quantity < 10."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-LS01 Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('TC-LS08 All results have quantity < 10', function () {",
                  "    var products = pm.response.json();",
                  "    products.forEach(function(p) {",
                  "        pm.expect(p.quantity, 'Product id=' + p.id + ' quantity=' + p.quantity).to.be.below(10);",
                  "    });",
                  "});",
                  "",
                  "pm.test('TC-LS08 All results have isLowStock=true', function () {",
                  "    var products = pm.response.json();",
                  "    products.forEach(function(p) {",
                  "        pm.expect(p.isLowStock, 'isLowStock for id=' + p.id).to.be.true;",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
